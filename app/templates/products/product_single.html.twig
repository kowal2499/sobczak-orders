{% extends 'base.html.twig' %}
{% trans_default_domain 'products' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}

    <section-block-title block title="{{ title }}" :breadcrumbs="[
        { icon: 'home', href: '/', label: '{{ 'Pulpit'|trans|e('js') }}' },
        { href: '{{ path('products_show') }}', label: '{{ 'Lista produktów'|trans|e('js') }}' },
        { label: '{{ (app.request.attributes.get('_route') == 'products_new' ? 'Nowy produkt' : 'Edycja produktu')|trans|e('js') }}' }
    ]"></section-block-title>

    <section-block class="section-gap">
        {{ form_start(form) }}

            {{ form_widget(form) }}

            <a href="{{ path('products_show') }}" class="btn btn-light mr-3">
                <i class="fa fa-arrow-left" aria-hidden="true"></i> {{ 'Wstecz'|trans }}
            </a>
            <button type="submit" class="btn-primary btn">
                <i class="fa fa-check-square-o" aria-hidden="true"></i> {{ 'Zapisz'|trans }}
            </button>

        {{ form_end(form) }}
    </section-block>

{% endblock %}
