{% extends 'base.html.twig' %}
{% trans_default_domain 'security' %}

{% block title %}

    {% if user is not null %}
        {{ 'Panel użytkownika:'|trans }} {{ user.getUserFullName }}
    {% else %}
        {{ 'Nowy użytkownik'|trans }}
    {% endif %}

{% endblock %}

{% block body %}
    {% set pageTitle = user is not null ? ('Panel użytkownika:'|trans ~ ' ' ~ user.getUserFullName) : 'Nowy użytkownik'|trans %}
    <app>
        <section-block-title block title="{{ pageTitle }}" :breadcrumbs="[
            { icon: 'home', href: '/', label: '{{ 'Pulpit'|trans|e('js') }}' },
            { label: '{{ 'Konfiguracja'|trans|e('js') }}' },
            { href: '{{ path('security_users') }}', label: '{{ 'Użytkownicy'|trans|e('js') }}' },
            { label: '{{ (user is not null ? 'Edycja użytkownika' : 'Nowy użytkownik')|trans|e('js') }}' }
        ]"></section-block-title>

        <auth-configuration-wrapper>
            <user-single
                {% if user is not null %}
                    :user-id="{{ user.getId }}"
                {% endif %}
            ></user-single>
        </auth-configuration-wrapper>
    </app>
{% endblock %}

