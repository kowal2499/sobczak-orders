{% set active = app.request.attributes.get('_route') %}
{% trans_default_domain 'base' %}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="icon" href="/imgs/sobczak.ico">
    <title>{% block title %}{% endblock %}</title>
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        {{ encore_entry_link_tags('app-vue') }}
    {% endblock %}
    {# Critical inline styles: render the sidebar collapsed (icons only) from the
       first paint so the bundled stylesheet doesn't flash expanded labels. #}
    <style>
        #wrapper nav.sidebar .sidebar__label,
        #wrapper nav.sidebar .submenu,
        #wrapper nav.sidebar .sidebar__footer .dropdown-menu,
        #wrapper nav.sidebar .sidebar__brand .sidebar__logo-full { display: none; }
        #wrapper nav.sidebar { width: 3.8rem; overflow: hidden; background: #f8f9fc; border-right: 1px solid #d6d6d6; }
        #content-wrapper { margin-left: 3.8rem; }
        /* Hide the burger/backdrop pre-load on desktop only — on mobile the
           bundle's media query must be able to reveal the burger. */
        @media (min-width: 768px) {
            #wrapper .sidebar-burger,
            #wrapper .sidebar-backdrop { display: none; }
        }
    </style>
</head>
<body id="page-top">

<div id="app">
    <div id="wrapper">

        {% include('_sidebar.html.twig') %}

        <button type="button" class="sidebar-burger" aria-label="{{ 'Menu'|trans }}">
            <i class="fa fa-bars" aria-hidden="true"></i>
        </button>
        <div class="sidebar-backdrop"></div>

        <div id="content-wrapper" class="d-flex flex-column">

            <!-- Main Content -->
            <div id="content">

                <notifications :bag="[

                            {% for message in app.flashes('success') %}
                                {
                                    type: 'success',
                                    content: '{{ message }}'
                                },
                            {% endfor %}

                        ]"></notifications>


                <div class="container-fluid">
                    {% block body %}{% endblock %}
                </div>
            </div>
        </div>
    </div>
</div>

{% block javascripts %}
    {{ encore_entry_script_tags('app') }}
    {{ encore_entry_script_tags('app-vue') }}
{% endblock %}

{% set userInfo = {
    id: app.user.id,
    firstName: app.user.firstName,
    lastName: app.user.lastName,
    roles: app.user.roles,
    locale: app.request.locale,
    isImpersonated: is_granted('IS_IMPERSONATOR')
} %}

<div id="js-usr" data-user-info="{{ userInfo|json_encode|url_encode }}"></div>

</body>
</html>