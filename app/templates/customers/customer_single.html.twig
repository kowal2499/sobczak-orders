{% extends 'base.html.twig' %}
{% trans_default_domain 'customers' %}

{% block title %}{{ title }}{% endblock %}

{% block breadcrumbs %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="{{ path('dashboard_show') }}" aria-label="Pulpit"><i class="fa fa-home" aria-hidden="true"></i></a></li>
        <li class="breadcrumb-item"><a href="{{ path('customers_show') }}">Lista klientów</a></li>
        <li class="breadcrumb-item active" aria-current="page">
            {{ app.request.attributes.get('_route') == 'customers_new' ? 'Nowy klient' : 'Edycja klienta' }}
        </li>
    </ol>
</nav>
{% endblock %}

{% block body %}

    <div class="card shadow mb-4">

        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">{{ title }}</h6>
        </div>

        <div class="card-body">

            {{ form_start(form) }}

                {{ form_row(form.name) }}

                <div class="row">
                    <div class="col-md-8">
                        {{ form_row(form.street) }}
                    </div>
                    <div class="col-md-2">
                        {{ form_row(form.street_number) }}
                    </div>
                    <div class="col-md-2">
                        {{ form_row(form.apartment_number) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        {{ form_row(form.postal_code) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.city) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.country) }}
                    </div>
                </div>


                <div class="row">
                    <div class="col">
                        {{ form_row(form.first_name) }}
                    </div>
                    <div class="col">
                        {{ form_row(form.last_name) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col">
                        {{ form_row(form.phone) }}
                    </div>

                    <div class="col">
                        {{ form_row(form.email) }}
                    </div>
                </div>

                <button type="submit" class="btn-primary btn"><i class="fa fa-check-square-o" aria-hidden="true"></i> {{ 'Zapisz'|trans }}</button>

            {{ form_end(form) }}

        </div>

    </div>

{% endblock %}